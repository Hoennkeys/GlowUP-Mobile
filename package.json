{
  "name": "GlowUPMobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "adb reverse tcp:8081 tcp:8081 && react-native run-android --no-packager",
    "android:build": "react-native bundle --platform android --dev true --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/ && cd android && gradlew.bat assembleDebug",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:offline": "npm run android:build && npm run android:install",
    "android:usb": "adb reverse tcp:8081 tcp:8081 && adb devices",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 react-native start",
    "storybook": "cross-env NODE_OPTIONS=--max-old-space-size=8192 STORYBOOK_ENABLED=true react-native start",
    "storybook:android": "cross-env STORYBOOK_ENABLED=true react-native run-android --appIdSuffix storybook",
    "test": "jest",
    "test:unit": "jest --testPathPattern=src/__tests__",
    "test:e2e": "detox test -c android.emu.debug",
    "test:e2e:build": "detox build -c android.emu.debug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "@supabase/supabase-js": "^2.110.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-image-picker": "^8.2.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@storybook/addon-ondevice-actions": "^10.4.7",
    "@storybook/addon-ondevice-controls": "^10.4.7",
    "@storybook/react-native": "^10.4.7",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "cross-env": "^10.1.0",
    "detox": "^20.51.4",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "jest-circus": "^30.4.2",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
